# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ce fichier .env.example ne contient aucun secret — il sert de modèle.

# LLM — si GROQ_API_KEY est défini, Jobster utilise Groq (cloud, gratuit).
# Sinon, il utilise Ollama en local (nécessite `ollama run qwen3:1.7b`).
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# France Travail — compte développeur gratuit sur https://francetravail.io
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Adzuna — compte développeur gratuit sur https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
